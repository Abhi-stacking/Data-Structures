#include <iostream>
using namespace std;

void rowsum(int arr[][4], int row, int col){
    for(row = 0; row<3; row++){
        int sum = 0;
        for(col = 0; col<4; col++){
        sum += arr[row][col];
        }
        cout<<sum<<endl;
    }   
}

int main() {
    int arr[3][4];
    
    for(int i = 0; i<3; i++){
        for(int j = 0; j<4; j++){
            cin>> arr[i][j];
        }
    }
    rowsum(arr, 3, 4);
    
}

